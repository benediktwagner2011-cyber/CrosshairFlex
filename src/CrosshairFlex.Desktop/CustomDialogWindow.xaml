<Window x:Class="CrosshairFlex.Desktop.CustomDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrosshairFlex"
        Width="520"
        Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0A1220"
        Foreground="#E6EDF7">
    <Border Margin="20" Padding="20" Background="#101A2B" CornerRadius="16" BorderBrush="#25384F" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="SecondaryButton" Width="100" Height="34" Margin="0,0,8,0" Click="SecondaryButton_OnClick" Visibility="Collapsed" />
                <Button x:Name="PrimaryButton" Width="100" Height="34" Click="PrimaryButton_OnClick" />
            </StackPanel>
            <StackPanel>
                <TextBlock x:Name="HeadingText" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10" />
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
